00111"},{"objCls":"Variant","id":"PA166395301","symbol":"rs1800112","name":"rs1800112"},{"objCls":"Variant","id":"PA166395102","symbol":"rs1800120","name":"rs1800120"},{"objCls":"Variant","id":"PA166164957","symbol":"rs186045772","name":"rs186045772"},{"objCls":"Variant","id":"PA166299361","symbol":"rs186089140","name":"rs186089140"},{"objCls":"Variant","id":"PA166157534","symbol":"rs193922525","name":"rs193922525"},{"objCls":"Variant","id":"PA166164954","symbol":"rs200321110","name":"rs200321110"},{"objCls":"Variant","id":"PA166394983","symbol":"rs201759207","name":"rs201759207"},{"objCls":"Variant","id":"PA166394721","symbol":"rs201958172","name":"rs201958172"},{"objCls":"Variant","id":"PA166164956","symbol":"rs202179988","name":"rs202179988"},{"objCls":"Variant","id":"PA166394421","symbol":"rs2116683801","name":"rs2116683801"},{"objCls":"Variant","id":"PA166157537","symbol":"rs267606723","name":"rs267606723"},{"objCls":"Variant","id":"PA166365261","symbol":"rs35516286","name":"rs35516286"},{"objCls":"Variant","id":"PA166164940","symbol":"rs368505753","name":"rs368505753"},{"objCls":"Variant","id":"PA166394802","symbol":"rs376008630","name":"rs376008630"},{"objCls":"Variant","id":"PA166395001","symbol":"rs386134230","name":"rs386134230"},{"objCls":"Variant","id":"PA166395141","symbol":"rs397508153","name":"rs397508153"},{"objCls":"Variant","id":"PA166164939","symbol":"rs397508256","name":"rs397508256"},{"objCls":"Variant","id":"PA166164948","symbol":"rs397508288","name":"rs397508288"},{"objCls":"Variant","id":"PA166394662","symbol":"rs397508300","name":"rs397508300"},{"objCls":"Variant","id":"PA166395162","symbol":"rs397508378","name":"rs397508378"},{"objCls":"Variant","id":"PA166196982","symbol":"rs397508387","name":"rs397508387"},{"objCls":"Variant","id":"PA166395163","symbol":"rs397508440","name":"rs397508440"},{"objCls":"Variant","id":"PA166164949","symbol":"rs397508442","name":"rs397508442"},{"objCls":"Variant","id":"PA166164952","symbol":"rs397508513","name":"rs397508513"},{"objCls":"Variant","id":"PA166164942","symbol":"rs397508537","name":"rs397508537"},{"objCls":"Variant","id":"PA166394341","symbol":"rs397508556","name":"rs397508556"},{"objCls":"Variant","id":"PA166394581","symbol":"rs397508572","name":"rs397508572"},{"objCls":"Variant","id":"PA166394541","symbol":"rs397508573","name":"rs397508573"},{"objCls":"Variant","id":"PA166178193","symbol":"rs397508602","name":"rs397508602"},{"objCls":"Variant","id":"PA166395061","symbol":"rs397508616","name":"rs397508616"},{"objCls":"Variant","id":"PA166394521","symbol":"rs397508621","name":"rs397508621"},{"objCls":"Variant","id":"PA166395181","symbol":"rs397508678","name":"rs397508678"},{"objCls":"Variant","id":"PA166394901","symbol":"rs397508721","name":"rs397508721"},{"objCls":"Variant","id":"PA166394681","symbol":"rs397508744","name":"rs397508744"},{"objCls":"Variant","id":"PA166394762","symbol":"rs397508748","name":"rs397508748"},{"objCls":"Variant","id":"PA166394881","symbol":"rs397508758","name":"rs397508758"},{"objCls":"Variant","id":"PA166196981","symbol":"rs397508761","name":"rs397508761"},{"objCls":"Variant","id":"PA166394302","symbol":"rs397508783","name":"rs397508783"},{"objCls":"Variant","id":"PA166394641","symbol":"rs397508784","name":"rs397508784"},{"objCls":"Variant","id":"PA166395101","symbol":"rs397508785","name":"rs397508785"},{"objCls":"Variant","id":"PA166157511","symbol":"rs74503330","name":"rs74503330"},{"objCls":"Variant","id":"PA166162705","symbol":"rs74551128","name":"rs74551128"},{"objCls":"Variant","id":"PA166394481","symbol":"rs74571530","name":"rs74571530"},{"objCls":"Variant","id":"PA166157514","symbol":"rs75039782","name":"rs75039782"},{"objCls":"Variant","id":"PA166157516","symbol":"rs75527207","name":"rs75527207"},{"objCls":"Variant","id":"PA166164958","symbol":"rs75541969","name":"rs75541969"},{"objCls":"Variant","id":"PA166394841","symbol":"rs75763344","name":"rs75763344"},{"objCls":"Variant","id":"PA166394842","symbol":"rs758818611","name":"rs758818611"},{"objCls":"Variant","id":"PA166184909","symbol":"rs76151804","name":"rs76151804"},{"objCls":"Variant","id":"PA166394741","symbol":"rs769016520","name":"rs769016520"},{"objCls":"Variant","id":"PA166178052","symbol":"rs77409459","name":"rs77409459"},{"objCls":"Variant","id":"PA166164944","symbol":"rs77834169","name":"rs77834169"},{"objCls":"Variant","id":"PA166395161","symbol":"rs77902683","name":"rs77902683"},{"objCls":"Variant","id":"PA166161186","symbol":"rs77932196","name":"rs77932196"},{"objCls":"Variant","id":"PA166157519","symbol":"rs78655421","name":"rs78655421"},{"objCls":"Variant","id":"PA166164955","symbol":"rs78769542","name":"rs78769542"},{"objCls":"Variant","id":"PA166162698","symbol":"rs80224560","name":"rs80224560"},{"objCls":"Variant","id":"PA166157521","symbol":"rs80282562","name":"rs80282562"}],"relatedChemicals":[{"objCls":"Chemical","id":"PA165950341","name":"ivacaftor"}],"relatedGenes":[{"objCls":"Gene","id":"PA109","symbol":"CFTR","name":"CF transmembrane conductance regulator"}],"source":"FDA","summaryMarkdown":{"id":1447981757,"html":"<p>Ivacaftor (KALYDECO) is indicated for the treatment of patients with cystic fibrosis (CF) who have a mutation in the <em>CFTR</em> gene that is responsive to ivacaftor based on clinical or in vitro data. Genetic testing is required prior to initiating treatment with ivacaftor if a patient's <em>CFTR</em> genotype is not known.</p>\n"},"testing":{"id":1183672041,"resource":"Genetic Testing Level","synonyms":[],"term":"Testing Required","termId":"geneTestLevel:1183672041","valid":true},"textMarkdown":{"id":1447981756,"html":"<p>Please refer to Table 3 in the drug label PDF (downloadable below) for a full list of mutations that are responsive to ivacaftor.</p>\n<p>Excerpts from the ivacaftor (KALYDECO) drug label:</p>\n<blockquote class=\"blockquote\">\n<p>KALYDECO is a cystic fibrosis transmembrane conductance regulator (CFTR) potentiator indicated for the treatment of cystic fibrosis (CF) in patients age 1 month and older who have at least one mutation in the CFTR gene that is responsive to ivacaftor based on clinical and/or in vitro assay data. (12.1, 14)</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>If the patient’s genotype is unknown, an FDA-cleared CF mutation test should be used to detect the presence of a CFTR mutation followed by verification with bi-directional sequencing when recommended by the mutation test instructions for use.</p>\n</blockquote>\n<p>For the complete drug label text with sections containing pharmacogenetic information highlighted, see the <a download=\"ivacaftor_FDA_20231005.pdf\" href=\"https://api.clinpgx.org/v1/download/file/attachment/ivacaftor_FDA_20231005.pdf\">ivacaftor drug label</a>.</p>\n"}},{"objCls":"Label Annotation","id":"PA166414521","name":"Annotation of FDA Label for efavirenz / emtricitabine / tenofovir disoproxil and CYP2B6","alternateDrugAvailable":false,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":15182922,"title":"DailyMed - EFAVIRENZ, EMTRICITABINE AND TENOFOVIR DISOPROXIL FUMARATE tablet, film coated","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=aca22076-f435-4533-9fcf-566b0734c313","crossReferences":[{"id":1454197420,"resource":"FDA Drug Label at DailyMed","resourceId":"aca22076-f435-4533-9fcf-566b0734c313","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=aca22076-f435-4533-9fcf-566b0734c313"}],"objCls":"Literature","terms":[{"id":1452267780,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":true,"pediatricMarkdown":{"id":1454197442,"html":"<blockquote class=\"blockquote\">\n<p>Efavirenz, emtricitabine and tenofovir disoproxil fumarate tablets are indicated as a complete regimen or in combination with other antiretroviral agents for the treatment of HIV-1 infection in adults and pediatric patients weighing at least 40 kg.</p>\n</blockquote>\n"},"pgxRelated":true,"prescribingGenes":[],"relatedAlleles":[{"objCls":"Haplotype","id":"PA165818762","symbol":"CYP2B6*6","name":"*6"}],"relatedChemicals":[{"objCls":"Chemical","id":"PA166176033","name":"efavirenz / emtricitabine / tenofovir disoproxil"}],"relatedGenes":[{"objCls":"Gene","id":"PA123","symbol":"CYP2B6","name":"cytochrome P450 family 2 subfamily B member 6"}],"source":"FDA","summaryMarkdown":{"id":1454197440,"html":"<p>The drug label for efavirenz, emtricitabine and tenofovir disoproxil fumarate states that patients with the CYP2B6*6/*6 genotype may have increased plasma exposure of efavirenz.</p>\n"},"testing":{"id":1183672141,"resource":"Genetic Testing Level","synonyms":[],"term":"Informative PGx","termId":"geneTestLevel:1183672141","valid":true},"textMarkdown":{"id":1454197441,"html":"<p>Excerpts from the efavirenz, emtricitabine and tenofovir disoproxil fumarate label:</p>\n<blockquote class=\"blockquote\">\n<p><em>In vitro</em> studies suggest CYP3A and CYP2B6 are the major isozymes responsible for EFV [efavirenz] metabolism.</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p><em>Efavirenz:</em> The effect of EFV on the QTc interval was evaluated in an open-label, positive and placebo-controlled, fixed single sequence 3-period, 3-treatment crossover QT study in 58 healthy subjects enriched for CYP2B6 polymorphisms. The mean C of EFV in subjects with CYP2B6 *6/*6 genotype following the administration of 600 mg daily dose for 14 days was 2.25-fold the mean C observed in subjects with CYP2B6 *1/*1 genotype. A positive relationship between EFV concentration and QTc prolongation was observed. Based on the concentration-QTc relationship, the mean QTc prolongation and its upper bound 90% confidence interval are 8.7 msec and 11.3 msec in subjects with CYP2B6*6/*6 genotype following the administration of 600 mg daily dose for 14 days [see Warnings and Precautions (5.4)].</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Late-onset neurotoxicity, including ataxia and encephalopathy (impaired consciousness, confusion, psychomotor slowing, psychosis, delirium), may occur months to years after beginning EFV therapy. Some events of late-onset neurotoxicity have occurred in patients with CYP2B6 genetic polymorphisms which are associated with increased EFV\nlevels despite standard dosing of EFV. Patients presenting with signs and symptoms of serious neurologic adverse experiences should be evaluated promptly to assess the\npossibility that these events may be related to EFV use, and whether discontinuation of efavirenz, emtricitabine and tenofovir disoproxil fumarate is warranted.</p>\n</blockquote>\n<p>For the complete drug label text with sections containing pharmacogenetic information highlighted, see the <a download=\"Efavirenz_emtricitabine_tenofovirdisoproxil_2025_08_04_FDA.pdf\" href=\"https://api.clinpgx.org/v1/download/file/attachment/Efavirenz_emtricitabine_tenofovirdisoproxil_2025_08_04_FDA.pdf\">efavirenz, emtricitabine and tenofovir disoproxil fumarate drug label</a>.</p>\n"}},{"objCls":"Label Annotation","id":"PA166414701","name":"Annotation of FDA Label for ethinyl estradiol / norelgestromin and F5, PROC, PROS1, SERPINC1","alternateDrugAvailable":true,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":15182962,"title":"DailyMed - NORELGESTROMIN AND ETHINYL ESTRADIOL patch","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=10fa1458-c8ed-4197-922a-1ba7271d2b02","crossReferences":[{"id":1454200560,"resource":"FDA Drug Label at DailyMed","resourceId":"10fa1458-c8ed-4197-922a-1ba7271d2b02","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=10fa1458-c8ed-4197-922a-1ba7271d2b02"}],"objCls":"Literature","terms":[{"id":1452267780,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":true,"pediatricMarkdown":{"id":1454200564,"html":"<blockquote class=\"blockquote\">\n<p>Safety and efficacy of norelgestromin and ethinyl estradiol transdermal system have been established in women of reproductive age. Efficacy is expected to be the same for post-pubertal adolescents under the age of 18 and for users 18 years and older. Use of this product before menarche is not indicated.</p>\n</blockquote>\n"},"pgxRelated":true,"prescribingGenes":[{"objCls":"Gene","id":"PA159","symbol":"F5","name":"coagulation factor V"},{"objCls":"Gene","id":"PA33799","symbol":"PROC","name":"protein C, inactivator of coagulation factors Va and VIIIa"},{"objCls":"Gene","id":"PA33809","symbol":"PROS1","name":"protein S"},{"objCls":"Gene","id":"PA35026","symbol":"SERPINC1","name":"serpin family C member 1"}],"prescribingMarkdown":{"id":1454200563,"html":"<blockquote class=\"blockquote\">\n<p>Norelgestromin and ethinyl estradiol transdermal system is contraindicated in females who [...] have inherited or acquired hypercoagulopathies</p>\n</blockquote>\n"},"relatedAlleles":[{"objCls":"Variant","id":"PA166153554","symbol":"rs6025","name":"rs6025"}],"relatedChemicals":[{"objCls":"Chemical","id":"PA165290929","name":"ethinyl estradiol / norelgestromin"}],"relatedGenes":[{"objCls":"Gene","id":"PA159","symbol":"F5","name":"coagulation factor V"},{"objCls":"Gene","id":"PA33799","symbol":"PROC","name":"protein C, inactivator of coagulation factors Va and VIIIa"},{"objCls":"Gene","id":"PA33809","symbol":"PROS1","name":"protein S"},{"objCls":"Gene","id":"PA35026","symbol":"SERPINC1","name":"serpin family C member 1"}],"source":"FDA","summaryMarkdown":{"id":1454200561,"html":"<p>Norelgestromin and ethinyl estradiol transdermal system is contraindicated in patients who have inherited hypercoagulopathies, among other contraindications. Although not mentioned on the drug label, known inherited hypercoagulopathies include deficiencies of antithrombin (SERPINC1), protein C (PROC) and protein S (PROS1), and the resistance to APC (factor V Leiden).</p>\n"},"testing":{"id":1183672111,"resource":"Genetic Testing Level","synonyms":[],"term":"Actionable PGx","termId":"geneTestLevel:1183672111","valid":true},"textMarkdown":{"id":1454200562,"html":"<p>Excerpts from the norelgestromin and ethinyl estradiol transdermal system label:</p>\n<blockquote class=\"blockquote\">\n<p>Norelgestromin and ethinyl estradiol transdermal system is contraindicated in females who are known to have or develop the following conditions:\n● At high risk of arterial or venous thromboembolic events. Examples include women who: [...]</p>\n<ul>\n<li>Have inherited or acquired hypercoagulopathies [see Warnings and Precautions (5.1)]</li>\n</ul>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Before starting norelgestromin and ethinyl estradiol transdermal system, evaluate any past medical history or family history of thrombotic or thromboembolic disorders and consider whether the history suggests an inherited or acquired hypercoagulopathy [see Contraindications (4)].</p>\n</blockquote>\n<p>For the complete drug label text with sections containing pharmacogenetic information highlighted, see the <a download=\"Norelgestromin_ethinyl_estradiol_2025_08_05_FDA.pdf\" href=\"https://api.clinpgx.org/v1/download/file/attachment/Norelgestromin_ethinyl_estradiol_2025_08_05_FDA.pdf\">norelgestromin and ethinyl estradiol drug label</a>.</p>\n"}},{"objCls":"Label Annotation","id":"PA166104788","name":"Annotation of FDA Label for fluoxetine / olanzapine and CYP2D6","alternateDrugAvailable":false,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[{"id":1183681712,"date":"2013-10-25T14:46:46.360-07:00","type":"Update","version":0},{"id":1183701081,"date":"2013-12-17T09:26:12.231-08:00","description":"Removed from FDA Biomarker Table","type":"Update","version":0},{"id":1454200825,"date":"2025-08-05T12:06:43.119-07:00","description":"updated label, changed PGx level to Actionable and added Prescribing Info, added Pediatric tag and info","type":"Update","version":0}],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":15183002,"title":"DailyMed - OLANZAPINE AND FLUOXETINE capsule","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=3c28cf18-01a3-468a-ab3e-8aa82f918251","crossReferences":[{"id":1454200820,"resource":"FDA Drug Label at DailyMed","resourceId":"3c28cf18-01a3-468a-ab3e-8aa82f918251","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=3c28cf18-01a3-468a-ab3e-8aa82f918251"}],"objCls":"Literature","terms":[{"id":1452267780,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"},{"id":15102036,"title":"Drugs@FDA: Drug Product Symbyax (Olanzapine and Fluoxetine hydrochloride), NDA021520, Eli Lilly and Company","_sameAs":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event=overview.process&varApplNo=021520","crossReferences":[{"id":1449754665,"resource":"FDA Application","resourceId":"NDA021520","_url":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event=overview.process&varApplNo=021520"}],"objCls":"Literature","terms":[{"id":1452267780,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":true,"pediatric":true,"pediatricMarkdown":{"id":1454200824,"html":"<blockquote class=\"blockquote\">\n<p>The safety and efficacy of olanzapine and fluoxetine capsules in patients 10 to 17 years of age has been established for the acute treatment of Depressive Episodes Associated with Bipolar I Disorder in a single 8-week randomized, placebo-controlled clinical trial (N = 255) [see Clinical Studies (14.1)].</p>\n</blockquote>\n"},"pgxRelated":true,"prescribingGenes":[{"objCls":"Gene","id":"PA128","symbol":"CYP2D6","name":"cytochrome P450 family 2 subfamily D member 6"}],"prescribingMarkdown":{"id":1454200823,"html":"<blockquote class=\"blockquote\">\n<p>Post-marketing cases of QT interval prolongation and ventricular arrhythmia including Torsade de Pointes have been reported in patients treated with fluoxetine. Olanzapine and fluoxetine capsules should be used with caution in patients with congenital long QT syndrome; a previous history of QT prolongation; a family history of long QT syndrome or sudden cardiac death; and other conditions that predispose to QT prolongation and ventricular arrhythmia. Such conditions include [...] conditions that predispose to increased fluoxetine exposure (overdose, hepatic impairment, use of CYP2D6 inhibitors, CYP2D6 poor metabolizer status, or use of other highly protein-bound drugs).</p>\n</blockquote>\n"},"relatedAlleles":[],"relatedChemicals":[{"objCls":"Chemical","id":"PA166176027","name":"fluoxetine / olanzapine"}],"relatedGenes":[{"objCls":"Gene","id":"PA128","symbol":"CYP2D6","name":"cytochrome P450 family 2 subfamily D member 6"}],"source":"FDA","summaryMarkdown":{"id":1450361452,"html":"<p>The FDA-approved drug label for olanzapine and fluoxetine states that fluoxetine is primarily metabolized by CYP2D6, and individuals who are CYP2D6 poor metabolizers metabolized <em>S</em>-fluoxetine at a slower rate and achieved higher concentrations. Olanzapine and fluoxetine capsules should be used used with caution in patients with congenital long QT syndrome; a previous history of QT prolongation and other conditions that predispose to QT prolongation and ventricular arrhythmia, which include patients with CYP2D6 poor metabolizer status.</p>\n"},"testing":{"id":1183672111,"resource":"Genetic Testing Level","synonyms":[],"term":"Actionable PGx","termId":"geneTestLevel:1183672111","valid":true},"textMarkdown":{"id":1450361454,"html":"<p>Excerpts from the olanzapine and fluoxetine drug label:</p>\n<blockquote class=\"blockquote\">\n<p><strong>QT Prolongation</strong>\nPost-marketing cases of QT interval prolongation and ventricular arrhythmia including Torsade de Pointes have been reported in patients treated with fluoxetine. Olanzapine and fluoxetine capsules should be used with caution in patients with congenital long QT syndrome; a previous history of QT prolongation; a family history of long QT syndrome or sudden cardiac death; and other conditions that predispose to QT prolongation and ventricular arrhythmia. Such conditions include concomitant use of drugs that prolong the QT interval; hypokalemia or hypomagnesemia; recent myocardial infarction, uncompensated heart failure, bradyarrhythmias, and other significant arrhythmias; and conditions that predispose to increased fluoxetine exposure (overdose, hepatic impairment, use of CYP2D6 inhibitors, CYP2D6 poor metabolizer status, or use of other highly protein-bound drugs). Fluoxetine is primarily metabolized by CYP2D6 [see Contraindications (4.2), Adverse Reactions (6), Drug Interactions (7.7, 7.8), Overdosage\n(10.1), and Clinical Pharmacology (12.3)].</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Fluoxetine is extensively metabolized in the liver to its only identified active metabolite, norfluoxetine, via the CYP2D6 pathway. A number of unidentified metabolites exist.</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Direct glucuronidation and CYP450-mediated oxidation are the primary metabolic pathways for olanzapine. <em>In vitro</em> studies suggest that CYP1A2, CYP2D6, and the flavin-containing monooxygenase system are involved in olanzapine oxidation. CYP2D6-mediated oxidation appears to be a minor metabolic pathway <em>in vivo</em>, because the clearance of olanzapine is not reduced in subjects who are deficient in this enzyme.</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>A subset (about 7%) of the population has reduced activity of the drug metabolizing enzyme CYP2D6. Such individuals are referred to as “poor\nmetabolizers” of drugs such as debrisoquin, dextromethorphan, and the tricyclic antidepressants (TCAs). In a study involving labeled and unlabeled enantiomers administered as a racemate, these individuals metabolized <em>S</em>-fluoxetine at a slower rate and thus achieved higher concentrations of <em>S</em>-fluoxetine. Consequently, concentrations of <em>S</em>-norfluoxetine at steady state were lower. The metabolism of <em>R</em>-fluoxetine in these poor metabolizers appears normal. When compared with normal metabolizers, the total sum at steady state of the plasma concentrations of the 4 enantiomers was not\nsignificantly greater among poor metabolizers. Thus, the net pharmacodynamic activities were essentially the same. Alternative nonsaturable pathways (non-CYP2D6) also contribute to the metabolism of fluoxetine. This explains how fluoxetine achieves a steady-state concentration rather than increasing without limit.</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Because the metabolism of fluoxetine, like that of a number of other compounds including TCAs and other selective serotonin antidepressants, involves the CYP2D6 system, concomitant therapy with drugs also metabolized by this enzyme system (such as the TCAs) may lead to drug interactions [see Drug Interactions (7.7)].</p>\n</blockquote>\n<p>For the complete drug label text with sections containing pharmacogenetic information highlighted, see the <a download=\"Olanzapine_fluoxetine_2025_08_05_FDA.pdf\" href=\"https://api.clinpgx.org/v1/download/file/attachment/Olanzapine_fluoxetine_2025_08_05_FDA.pdf\">olanzapine and fluoxetine drug label</a>.</p>\n"}},{"objCls":"Label Annotation","id":"PA166416461","name":"Annotation of FDA Label for ranolazine","alternateDrugAvailable":false,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":15183762,"title":"DailyMed - RANOLAZINE tablet, film coated, extended release","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=5b254a8e-db88-49be-bb48-e6d2847f8ab3","crossReferences":[{"id":1454228820,"resource":"FDA Drug Label at DailyMed","resourceId":"5b254a8e-db88-49be-bb48-e6d2847f8ab3","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=5b254a8e-db88-49be-bb48-e6d2847f8ab3"}],"objCls":"Literature","terms":[{"id":1452267781,"resource":"ClinPGx Tags","term":"Has No PGx","termId":"pgkbTags:1452267781"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":false,"pgxRelated":true,"prescribingGenes":[],"relatedAlleles":[],"relatedChemicals":[{"objCls":"Chemical","id":"PA164746007","name":"ranolazine"}],"relatedGenes":[],"source":"FDA","summaryMarkdown":{"id":1454228821,"html":"<p>The FDA-approved drug label for ranolazine states that it is metabolized mainly by CYP3A and, to a lesser extent, by CYP2D6.</p>\n"},"textMarkdown":{"id":1454228822,"html":"<p>Excerpt from the ranolazine label:</p>\n<blockquote class=\"blockquote\">\n<p>Ranolazine is metabolized mainly by CYP3A and, to a lesser extent, by CYP2D6.</p>\n</blockquote>\n<p>For the complete drug label text with sections containing pharmacogenetic information highlighted, see the <a download=\"Ranolazine_2025_08_22_FDA.pdf\" href=\"https://api.clinpgx.org/v1/download/file/attachment/Ranolazine_2025_08_22_FDA.pdf\">ranolazine drug label</a>.</p>\n"}},{"objCls":"Label Annotation","id":"PA166419721","name":"Annotation of FDA Label for isoniazid and NAT2","alternateDrugAvailable":false,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":15185502,"title":"DailyMed - ISONIAZID tablet","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=312cd403-b211-64ef-e063-6394a90aab88","crossReferences":[{"id":1454274860,"resource":"FDA Drug Label at DailyMed","resourceId":"312cd403-b211-64ef-e063-6394a90aab88","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid=312cd403-b211-64ef-e063-6394a90aab88"}],"objCls":"Literature","terms":[{"id":1452267780,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":true,"pediatricMarkdown":{"id":1454274863,"html":"<blockquote class=\"blockquote\">\n<p><strong>DOSAGE AND ADMINISTRATION</strong> [...]</p>\n<p><strong>For Treatment of Tuberculosis</strong> [...]\nUsual Oral Dosage (depending on the regimen used): [...]</p>\n<p>Children</p>\n<p>10 mg/kg to 15 mg/kg up to 300 mg daily in a single dose; or</p>\n<p>20 mg/kg to 40 mg/kg up to 900 mg/day, two or three times/week</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p><strong>For Preventative Therapy of Tuberculosis</strong> [...]</p>\n<p>Infants and Children</p>\n<p>10 mg/kg (up to 300 mg daily) in a single dose. In situations where adherence with daily preventative therapy cannot be assured, 20 mg/kg to 30 mg/kg (not to exceed 900 mg) twice weekly under the direct observation of a health care worker at the time of administration</p>\n</blockquote>\n"},"pgxRelated":true,"prescribingGenes":[],"relatedAlleles":[],"relatedChemicals":[{"objCls":"Chemical","id":"PA450112","name":"isoniazid"}],"relatedGenes":[{"objCls":"Gene","id":"PA18","symbol":"NAT2","name":"N-acetyltransferase 2"}],"source":"FDA","summaryMarkdown":{"id":1454274861,"html":"<p>The FDA-approved drug label for isoniazid states that &quot;slow inactivators&quot; of isoniazid may be more susceptible to drug toxicity due to higher blood levels of the drug. Acetylator status of an individual can be determined by examining genetic variants in the NAT2 gene. However, the label never mentions any specific gene with regard to inactivator or acetylator status.</p>\n"},"testing":{"id":1183672141,"resource":"Genetic Testing Level","synonyms":[],"term":"Informative PGx","termId":"geneTestLevel:1183672141","valid":true},"textMarkdown":{"id":1454274862,"html":"<p>Excerpts from the isoniazid label:</p>\n<blockquote class=\"blockquote\">\n<p>Isoniazid is metabolized primarily by acetylation and dehydrazination. The rate of acetylation is genetically determined. Approximately 50 percent of Blacks and Caucasians are &quot;slow inactivators&quot; and the rest are &quot;rapid inactivators&quot;; the majority of Eskimos and Orientals are &quot;rapid inactivators.&quot;</p>\n<p>The rate of acetylation does not significantly alter the effectiveness of isoniazid. However, slow acetylation may lead to higher blood levels of the drug and, thus, to an\nincrease in toxic reactions.</p>\n</blockquote>\n<p>For the complete drug label text with sections containing pharmacogenetic information highlighted, see the <a download=\"Isoniazid_2025_09_25_FDA.pdf\" href=\"https://api.clinpgx.org/v1/download/file/attachment/Isoniazid_2025_09_25_FDA.pdf\">isoniazid drug label</a>.</p>\n"}},{"objCls":"Label Annotation","id":"PA166104802","name":"Annotation of FDA Label for capecitabine and DPYD","alternateDrugAvailable":true,"biomarkerStatus":"On FDA Biomarker List","cancerGenome":false,"crossReferences":[],"dosingInformation":true,"history":[{"id":1183681518,"date":"2013-10-25T12:25:22.795-07:00","type":"Update","version":0},{"id":1450399696,"date":"2019-05-10T08:42:29.125-07:00","description":"Added prescribing info","type":"Update","version":0},{"id":1451968500,"date":"2022-12-19T15:33:11.126-08:00","description":"update label, PGx level","type":"Update","version":0},{"id":1454288442,"date":"2025-10-08T10:10:41.762-07:00","description":"updated label and annotation, changed PGx level to Testing Required","type":"Update","version":0}],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":15186282,"title":"Drugs@FDA: Drug Product Xeloda (capecitabine), H2-Pharma, LLC - NDA020896/SUPPL-52, 10/03/2025","_sameAs":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event=overview.process&varApplNo=020896","crossReferences":[{"id":1454288441,"resource":"FDA Application","resourceId":"NDA020896/SUPPL-52","_url":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event=overview.process&varApplNo=020896"}],"objCls":"Literature","pubDate":"2025-10-03T00:00:00-07:00","terms":[{"id":1452267780,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"},{"id":15101916,"title":"Drugs@FDA: Drug Product Xeloda (capecitabine), NDA020896, Genentech, Inc.","_sameAs":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event=overview.process&varApplNo=020896","crossReferences":[{"id":1449894845,"resource":"FDA Application","resourceId":"NDA020896","_url":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event=overview.process&varApplNo=020896"}],"objCls":"Literature","terms":[{"id":1452267780,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":false,"pgxRelated":true,"prescribingGenes":[{"objCls":"Gene","id":"PA145","symbol":"DPYD","name":"dihydropyrimidine dehydrogenase"}],"prescribingMarkdown":{"id":1450399695,"html":"<p>Excerpts from the capecitabine (XELODA) drug label:</p>\n<blockquote class=\"blockquote\">\n<p>Prior to initiating XELODA, test patients for genetic variants of the <em>DPYD</em> gene unless immediate treatment is necessary [...]. Serious adverse reactions may still occur even if no DPYD variants are identified.</p>\n<p>Avoid use of XELODA in patients with certain homozygous or compound heterozygous <em>DPYD</em> variants that result in complete DPD deficiency.</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Patients with certain homozygous or compound heterozygous variants in the <em>DPYD</em> gene known to result in complete or near complete absence of DPD activity (complete DPD deficiency) are at increased risk for acute early-onset toxicity and serious, including fatal, adverse reactions due to XELODA (e.g., mucositis, diarrhea, neutropenia, and neurotoxicity). Patients with partial DPD activity (partial DPD deficiency) may also have increased risk of serious, or fatal, adverse reactions.</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Withhold or permanently discontinue XELODA based on clinical assessment of the onset, duration, and severity of adverse reactions in patients with evidence of acute early-onset or unusually severe reactions. No XELODA dose has been proven safe for patients with complete DPD deficiency. For patients with partial DPD deficiency, individualize the dosage and modify based on tolerability and intent of treatment.</p>\n</blockquote>\n"},"relatedAlleles":[{"objCls":"Haplotype","id":"PA166171120","symbol":"DPYD c.1129-5923C>G, c.1236G>A (HapB3)","name":"c.1129-5923C>G, c.1236G>A (HapB3)"},{"objCls":"Variant","id":"PA166153919","symbol":"rs115232898","name":"rs115232898"},{"objCls":"Variant","id":"PA166153760","symbol":"rs3918290","name":"rs3918290"},{"objCls":"Variant","id":"PA166153888","symbol":"rs55886062","name":"rs55886062"},{"objCls":"Variant","id":"PA166153895","symbol":"rs67376798","name":"rs67376798"},{"objCls":"Variant","id":"PA166153906","symbol":"rs75017182","name":"rs75017182"}],"relatedChemicals":[{"objCls":"Chemical","id":"PA448771","name":"capecitabine"}],"relatedGenes":[{"objCls":"Gene","id":"PA145","symbol":"DPYD","name":"dihydropyrimidine dehydrogenase"}],"source":"FDA","summaryMarkdown":{"id":1450342104,"html":"<p>The FDA-approved label for capecitabine (XELODA) states that patients should be tested for genetic variants of the <em>DPYD</em> gene prior to initiating treatment unless immediate treatment is necessary. Patients with certain homozygous or compound heterozygous variants in the <em>DPYD</em> gene are at increased risk for acute early-onset toxicity and serious, including fatal, adverse reactions due to capecitabine.  Patients with partial DPD deficiency may also have increased risk of serious, or fatal, adverse reactions; their dosage should be individualized and modified based on tolerability and intent of treatment.</p>\n"},"testing":{"id":1183672041,"resource":"Genetic Testing Level","synonyms":[],"term":"Testing Required","termId":"geneTestLevel:1183672041","valid":true},"textMarkdown":{"id":1450342105,"html":"<p>Capecitabine is a pro-drug of 5-fluorouracil used for the treatment of various types of neoplasms including colorectal and breast neoplasms. Variants in the <em>DPYD</em> gene (also known as dihydropyrimidine dehydrogenase and DPD) are associated with increased risk for adverse events. See the <a href=\"/pathway/PA150653776\">Fluroropyrimidine Pathway</a> and <a href=\"/vip/PA145\">DPYD VIP</a> for more information.</p>\n<p>Excerpts from the capecitabine (XELODA) drug label:</p>\n<blockquote class=\"blockquote\">\n<p>Prior to initiating XELODA, test patients for genetic variants of the <em>DPYD</em> gene unless immediate treatment is necessary. An FDA-authorized test for the detection of the <em>DPYD</em> gene to identify patients at risk of serious adverse reactions with XELODA is not currently available. Currently available tests used to identify <em>DPYD</em> variants may vary in accuracy and design (e.g., which <em>DPYD</em> variant(s) they identify).</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Avoid use of XELODA in patients known to have certain homozygous or compound heterozygous <em>DPYD</em> variants that result in complete DPD deficiency. No XELODA dose has been proven safe for patients with complete DPD deficiency. For patients with partial DPD deficiency, individualize the dosage and modify based on tolerability and intent of treatment [see Warnings and Precautions (5.1)].</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Patients with certain homozygous or compound heterozygous variants in the <em>DPYD</em> gene known to result in complete or near complete absence of DPD activity (complete DPD deficiency) are at increased risk for acute early-onset toxicity and serious, including fatal, adverse reactions due to XELODA (e.g., mucositis, diarrhea, neutropenia, and neurotoxicity). Patients with partial DPD activity (partial DPD deficiency) may also have increased risk of serious, or fatal, adverse reactions.</p>\n<p>Prior to initiating XELODA, test patients for genetic variants of the <em>DPYD</em> gene unless immediate treatment is necessary [see Clinical Pharmacology (12.5)]. Serious adverse reactions may still occur even if no <em>DPYD</em> variants are identified.</p>\n<p>Avoid use of XELODA in patients with certain homozygous or compound heterozygous <em>DPYD</em> variants that result in complete DPD deficiency.</p>\n<p>Withhold or permanently discontinue XELODA based on clinical assessment of the onset, duration, and severity of adverse reactions in patients with evidence of acute early-onset or unusually severe reactions. No XELODA dose has been proven safe for patients with complete DPD deficiency. For patients with partial DPD deficiency, individualize the dosage and modify based on tolerability and intent of treatment.</p>\n</blockquote>\n<blockquote class=\"blockquote\">\n<p>Pharmacogenomics: The <em>DPYD</em> gene encodes the enzyme DPD, which is responsible for the catabolism of &gt;80% of fluorouracil. Approximately 3-5% of White populations have partial DPD deficiency and 0.2% of White populations have complete DPD deficiency, which may be due to certain genetic no function or decreased function variants in <em>DPYD</em> resulting in partial to complete or near complete absence of enzyme activity. DPD deficiency is estimated to be more prevalent in Black or African American populations compared to White populations. Insufficient information is available to estimate the prevalence of DPD deficiency in other populations.</p>\n<p>Patients who are homozygous or compound heterozygous for no function <em>DPYD</em> variants (i.e., carry two <em>DPYD</em> variants that results in no DPD enzyme activity) or are compound heterozygous for a no function <em>DPYD</em> variant plus a decreased function <em>DPYD</em> variant have complete DPD deficiency and are at increased risk for acute early-onset of toxicity and serious life-threatening, or fatal adverse reactions with XELODA. Partial DPD deficiency can result from the presence of either two decreased function <em>DPYD</em> variants or one normal function plus either a decreased function or a no function <em>DPYD</em> variant. Patients with partial DPD deficiency may also be at an increased risk for toxicity from XELODA.</p>\n<p>Several <em>DPYD</em> variants observed with variable frequency across populations have been associated with reduced or no DPD activity, especially when present as homozygous or compound heterozygous variants. These include c.1905+1G&gt;A (<em>DPYD</em> *2A), c.1679T&gt;G (<em>DPYD</em> *13), c.2846A&gt;T, c.1129-5923C&gt;G (Haplotype B3), and c557A&gt;G. <em>DPYD</em>*2A and <em>DPYD</em>*13 are no function variants, and c.2846A&gt;T, c.1129-5923C&gt;G, and c557A&gt;G are decreased function variants. This is not a complete listing of all <em>DPYD</em> variants that may result in DPD deficiency [see Warnings and Precautions (5.1)].</p>\n</blockquote>\n<p>For the complete drug label text with sections containing pharmacogenetic information highlighted, see the <a download=\"Capecitabine_2025_10_08_FDA.pdf\" href=\"https://api.clinpgx.org/v1/download/file/attachment/Capecitabine_2025_10_08_FDA.pdf\">capecitabine drug label</a>.</p>\n"}}],"status":"success"}