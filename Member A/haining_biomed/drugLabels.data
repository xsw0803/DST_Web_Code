ations":[],"labelDocumentAvailable":true,"literature":[{"id":1.51019E7,"title":"Drugs@FDA: Drug Product Kalydeco (ivacaftor), NDA203188, Vertex Pharmaceuticals Incorporated","_sameAs":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event\u003doverview.process\u0026varApplNo\u003d203188","crossReferences":[{"id":1.449754806E9,"resource":"FDA Application","resourceId":"NDA203188","_url":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event\u003doverview.process\u0026varApplNo\u003d203188"}],"objCls":"Literature","terms":[{"id":1.45226778E9,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":true,"pediatricMarkdown":{"id":1.454038902E9,"html":"\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eKALYDECO is a cystic fibrosis transmembrane conductance regulator (CFTR) potentiator indicated for the treatment of cystic fibrosis (CF) in patients age 1 month and older who have at least one mutation in the \u003cem\u003eCFTR\u003c/em\u003e gene that is responsive to ivacaftor based on clinical and/or \u003cem\u003ein vitro\u003c/em\u003e assay data.\u003c/p\u003e\n\u003c/blockquote\u003e\n"},"pgxRelated":true,"prescribingGenes":[],"relatedAlleles":[{"objCls":"Variant","id":"PA166164943","symbol":"rs113993958","name":"rs113993958"},{"objCls":"Variant","id":"PA166164941","symbol":"rs115545701","name":"rs115545701"},{"objCls":"Variant","id":"PA166164959","symbol":"rs11971167","name":"rs11971167"},{"objCls":"Variant","id":"PA166164946","symbol":"rs121908752","name":"rs121908752"},{"objCls":"Variant","id":"PA166164947","symbol":"rs121908753","name":"rs121908753"},{"objCls":"Variant","id":"PA166157529","symbol":"rs121908755","name":"rs121908755"},{"objCls":"Variant","id":"PA166157530","symbol":"rs121908757","name":"rs121908757"},{"objCls":"Variant","id":"PA166157531","symbol":"rs121909005","name":"rs121909005"},{"objCls":"Variant","id":"PA166157532","symbol":"