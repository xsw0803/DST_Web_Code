556","name":"rs397508556"},{"objCls":"Variant","id":"PA166394581","symbol":"rs397508572","name":"rs397508572"},{"objCls":"Variant","id":"PA166394541","symbol":"rs397508573","name":"rs397508573"},{"objCls":"Variant","id":"PA166178193","symbol":"rs397508602","name":"rs397508602"},{"objCls":"Variant","id":"PA166395061","symbol":"rs397508616","name":"rs397508616"},{"objCls":"Variant","id":"PA166394521","symbol":"rs397508621","name":"rs397508621"},{"objCls":"Variant","id":"PA166395181","symbol":"rs397508678","name":"rs397508678"},{"objCls":"Variant","id":"PA166394901","symbol":"rs397508721","name":"rs397508721"},{"objCls":"Variant","id":"PA166394681","symbol":"rs397508744","name":"rs397508744"},{"objCls":"Variant","id":"PA166394762","symbol":"rs397508748","name":"rs397508748"},{"objCls":"Variant","id":"PA166394881","symbol":"rs397508758","name":"rs397508758"},{"objCls":"Variant","id":"PA166196981","symbol":"rs397508761","name":"rs397508761"},{"objCls":"Variant","id":"PA166394302","symbol":"rs397508783","name":"rs397508783"},{"objCls":"Variant","id":"PA166394641","symbol":"rs397508784","name":"rs397508784"},{"objCls":"Variant","id":"PA166395101","symbol":"rs397508785","name":"rs397508785"},{"objCls":"Variant","id":"PA166157511","symbol":"rs74503330","name":"rs74503330"},{"objCls":"Variant","id":"PA166162705","symbol":"rs74551128","name":"rs74551128"},{"objCls":"Variant","id":"PA166394481","symbol":"rs74571530","name":"rs74571530"},{"objCls":"Variant","id":"PA166157514","symbol":"rs75039782","name":"rs75039782"},{"objCls":"Variant","id":"PA166157516","symbol":"rs75527207","name":"rs75527207"},{"objCls":"Variant","id":"PA166164958","symbol":"rs75541969","name":"rs75541969"},{"objCls":"Variant","id":"PA166394841","symbol":"rs75763344","name":"rs75763344"},{"objCls":"Variant","id":"PA166394842","symbol":"rs758818611","name":"rs758818611"},{"objCls":"Variant","id":"PA166184909","symbol":"rs76151804","name":"rs76151804"},{"objCls":"Variant","id":"PA166394741","symbol":"rs769016520","name":"rs769016520"},{"objCls":"Variant","id":"PA166178052","symbol":"rs77409459","name":"rs77409459"},{"objCls":"Variant","id":"PA166164944","symbol":"rs77834169","name":"rs77834169"},{"objCls":"Variant","id":"PA166395161","symbol":"rs77902683","name":"rs77902683"},{"objCls":"Variant","id":"PA166161186","symbol":"rs77932196","name":"rs77932196"},{"objCls":"Variant","id":"PA166157519","symbol":"rs78655421","name":"rs78655421"},{"objCls":"Variant","id":"PA166164955","symbol":"rs78769542","name":"rs78769542"},{"objCls":"Variant","id":"PA166162698","symbol":"rs80224560","name":"rs80224560"},{"objCls":"Variant","id":"PA166157521","symbol":"rs80282562","name":"rs80282562"}],"relatedChemicals":[{"objCls":"Chemical","id":"PA165950341","name":"ivacaftor"}],"relatedGenes":[{"objCls":"Gene","id":"PA109","symbol":"CFTR","name":"CF transmembrane conductance regulator"}],"source":"FDA","summaryMarkdown":{"id":1.447981757E9,"html":"\u003cp\u003eIvacaftor (KALYDECO) is indicated for the treatment of patients with cystic fibrosis (CF) who have a mutation in the \u003cem\u003eCFTR\u003c/em\u003e gene that is responsive to ivacaftor based on clinical or in vitro data. Genetic testing is required prior to initiating treatment with ivacaftor if a patient\u0027s \u003cem\u003eCFTR\u003c/em\u003e genotype is not known.\u003c/p\u003e\n"},"testing":{"id":1.183672041E9,"resource":"Genetic Testing Level","synonyms":[],"term":"Testing Required","termId":"geneTestLevel:1183672041","valid":true},"textMarkdown":{"id":1.447981756E9,"html":"\u003cp\u003ePlease refer to Table 3 in the drug label PDF (downloadable below) for a full list of mutations that are responsive to ivacaftor.\u003c/p\u003e\n\u003cp\u003eExcerpts from the ivacaftor (KALYDECO) drug label:\u003c/p\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eKALYDECO is a cystic fibrosis transmembrane conductance regulator (CFTR) potentiator indicated for the treatment of cystic fibrosis (CF) in patients age 1 month and older who have at least one mutation in the CFTR gene that is responsive to ivacaftor based on clinical and/or in vitro assay data. (12.1, 14)\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eIf the patient’s genotype is unknown, an FDA-cleared CF mutation test should be used to detect the presence of a CFTR mutation followed by verification with bi-directional sequencing when recommended by the mutation test instructions for use.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eFor the complete drug label text with sections containing pharmacogenetic information highlighted, see the \u003ca download\u003d\"ivacaftor_FDA_20231005.pdf\" href\u003d\"https://api.clinpgx.org/v1/download/file/attachment/ivacaftor_FDA_20231005.pdf\"\u003eivacaftor drug label\u003c/a\u003e.\u003c/p\u003e\n"}}
{"objCls":"Label Annotation","id":"PA166414521","name":"Annotation of FDA Label for efavirenz / emtricitabine / tenofovir disoproxil and CYP2B6","alternateDrugAvailable":false,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":1.5182922E7,"title":"DailyMed - EFAVIRENZ, EMTRICITABINE AND TENOFOVIR DISOPROXIL FUMARATE tablet, film coated","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003daca22076-f435-4533-9fcf-566b0734c313","crossReferences":[{"id":1.45419742E9,"resource":"FDA Drug Label at DailyMed","resourceId":"aca22076-f435-4533-9fcf-566b0734c313","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003daca22076-f435-4533-9fcf-566b0734c313"}],"objCls":"Literature","terms":[{"id":1.45226778E9,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":true,"pediatricMarkdown":{"id":1.454197442E9,"html":"\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eEfavirenz, emtricitabine and tenofovir disoproxil fumarate tablets are indicated as a complete regimen or in combination with other antiretroviral agents for the treatment of HIV-1 infection in adults and pediatric patients weighing at least 40 kg.\u003c/p\u003e\n\u003c/blockquote\u003e\n"},"pgxRelated":true,"prescribingGenes":[],"relatedAlleles":[{"objCls":"Haplotype","id":"PA165818762","symbol":"CYP2B6*6","name":"*6"}],"relatedChemicals":[{"objCls":"Chemical","id":"PA166176033","name":"efavirenz / emtricitabine / tenofovir disoproxil"}],"relatedGenes":[{"objCls":"Gene","id":"PA123","symbol":"CYP2B6","name":"cytochrome P450 family 2 subfamily B member 6"}],"source":"FDA","summaryMarkdown":{"id":1.45419744E9,"html":"\u003cp\u003eThe drug label for efavirenz, emtricitabine and tenofovir disoproxil fumarate states that patients with the CYP2B6*6/*6 genotype may have increased plasma exposure of efavirenz.\u003c/p\u003e\n"},"testing":{"id":1.183672141E9,"resource":"Genetic Testing Level","synonyms":[],"term":"Informative PGx","termId":"geneTestLevel:1183672141","valid":true},"textMarkdown":{"id":1.454197441E9,"html":"\u003cp\u003eExcerpts from the efavirenz, emtricitabine and tenofovir disoproxil fumarate label:\u003c/p\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003e\u003cem\u003eIn vitro\u003c/em\u003e studies suggest CYP3A and CYP2B6 are the major isozymes responsible for EFV [efavirenz] metabolism.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003e\u003cem\u003eEfavirenz:\u003c/em\u003e The effect of EFV on the QTc interval was evaluated in an open-label, positive and placebo-controlled, fixed single sequence 3-period, 3-treatment crossover QT study in 58 healthy subjects enriched for CYP2B6 polymorphisms. The mean C of EFV in subjects with CYP2B6 *6/*6 genotype following the administration of 600 mg daily dose for 14 days was 2.25-fold the mean C observed in subjects with CYP2B6 *1/*1 genotype. A positive relationship between EFV concentration and QTc prolongation was observed. Based on the concentration-QTc relationship, the mean QTc prolongation and its upper bound 90% confidence interval are 8.7 msec and 11.3 msec in subjects with CYP2B6*6/*6 genotype following the administration of 600 mg daily dose for 14 days [see Warnings and Precautions (5.4)].\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eLate-onset neurotoxicity, including ataxia and encephalopathy (impaired consciousness, confusion, psychomotor slowing, psychosis, delirium), may occur months to years after beginning EFV therapy. Some events of late-onset neurotoxicity have occurred in patients with CYP2B6 genetic polymorphisms which are associated with increased EFV\nlevels despite standard dosing of EFV. Patients presenting with signs and symptoms of serious neurologic adverse experiences should be evaluated promptly to assess the\npossibility that these events may be related to EFV use, and whether discontinuation of efavirenz, emtricitabine and tenofovir disoproxil fumarate is warranted.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eFor the complete drug label text with sections containing pharmacogenetic information highlighted, see the \u003ca download\u003d\"Efavirenz_emtricitabine_tenofovirdisoproxil_2025_08_04_FDA.pdf\" href\u003d\"https://api.clinpgx.org/v1/download/file/attachment/Efavirenz_emtricitabine_tenofovirdisoproxil_2025_08_04_FDA.pdf\"\u003eefavirenz, emtricitabine and tenofovir disoproxil fumarate drug label\u003c/a\u003e.\u003c/p\u003e\n"}}
{"objCls":"Label Annotation","id":"PA166414701","name":"Annotation of FDA Label for ethinyl estradiol / norelgestromin and F5, PROC, PROS1, SERPINC1","alternateDrugAvailable":true,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":1.5182962E7,"title":"DailyMed - NORELGESTROMIN AND ETHINYL ESTRADIOL patch","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003d10fa1458-c8ed-4197-922a-1ba7271d2b02","crossReferences":[{"id":1.45420056E9,"resource":"FDA Drug Label at DailyMed","resourceId":"10fa1458-c8ed-4197-922a-1ba7271d2b02","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003d10fa1458-c8ed-4197-922a-1ba7271d2b02"}],"objCls":"Literature","terms":[{"id":1.45226778E9,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":true,"pediatricMarkdown":{"id":1.454200564E9,"html":"\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eSafety and efficacy of norelgestromin and ethinyl estradiol transdermal system have been established in women of reproductive age. Efficacy is expected to be the same for post-pubertal adolescents under the age of 18 and for users 18 years and older. Use of this product before menarche is not indicated.\u003c/p\u003e\n\u003c/blockquote\u003e\n"},"pgxRelated":true,"prescribingGenes":[{"objCls":"Gene","id":"PA159","symbol":"F5","name":"coagulation factor V"},{"objCls":"Gene","id":"PA33799","symbol":"PROC","name":"protein C, inactivator of coagulation factors Va and VIIIa"},{"objCls":"Gene","id":"PA33809","symbol":"PROS1","name":"protein S"},{"objCls":"Gene","id":"PA35026","symbol":"SERPINC1","name":"serpin family C member 1"}],"prescribingMarkdown":{"id":1.454200563E9,"html":"\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eNorelgestromin and ethinyl estradiol transdermal system is contraindicated in females who [...] have inherited or acquired hypercoagulopathies\u003c/p\u003e\n\u003c/blockquote\u003e\n"},"relatedAlleles":[{"objCls":"Variant","id":"PA166153554","symbol":"rs6025","name":"rs6025"}],"relatedChemicals":[{"objCls":"Chemical","id":"PA165290929","name":"ethinyl estradiol / norelgestromin"}],"relatedGenes":[{"objCls":"Gene","id":"PA159","symbol":"F5","name":"coagulation factor V"},{"objCls":"Gene","id":"PA33799","symbol":"PROC","name":"protein C, inactivator of coagulation factors Va and VIIIa"},{"objCls":"Gene","id":"PA33809","symbol":"PROS1","name":"protein S"},{"objCls":"Gene","id":"PA35026","symbol":"SERPINC1","name":"serpin family C member 1"}],"source":"FDA","summaryMarkdown":{"id":1.454200561E9,"html":"\u003cp\u003eNorelgestromin and ethinyl estradiol transdermal system is contraindicated in patients who have inherited hypercoagulopathies, among other contraindications. Although not mentioned on the drug label, known inherited hypercoagulopathies include deficiencies of antithrombin (SERPINC1), protein C (PROC) and protein S (PROS1), and the resistance to APC (factor V Leiden).\u003c/p\u003e\n"},"testing":{"id":1.183672111E9,"resource":"Genetic Testing Level","synonyms":[],"term":"Actionable PGx","termId":"geneTestLevel:1183672111","valid":true},"textMarkdown":{"id":1.454200562E9,"html":"\u003cp\u003eExcerpts from the norelgestromin and ethinyl estradiol transdermal system label:\u003c/p\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eNorelgestromin and ethinyl estradiol transdermal system is contraindicated in females who are known to have or develop the following conditions:\n● At high risk of arterial or venous thromboembolic events. Examples include women who: [...]\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eHave inherited or acquired hypercoagulopathies [see Warnings and Precautions (5.1)]\u003c/li\u003e\n\u003c/ul\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eBefore starting norelgestromin and ethinyl estradiol transdermal system, evaluate any past medical history or family history of thrombotic or thromboembolic disorders and consider whether the history suggests an inherited or acquired hypercoagulopathy [see Contraindications (4)].\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eFor the complete drug label text with sections containing pharmacogenetic information highlighted, see the \u003ca download\u003d\"Norelgestromin_ethinyl_estradiol_2025_08_05_FDA.pdf\" href\u003d\"https://api.clinpgx.org/v1/download/file/attachment/Norelgestromin_ethinyl_estradiol_2025_08_05_FDA.pdf\"\u003enorelgestromin and ethinyl estradiol drug label\u003c/a\u003e.\u003c/p\u003e\n"}}
{"objCls":"Label Annotation","id":"PA166104788","name":"Annotation of FDA Label for fluoxetine / olanzapine and CYP2D6","alternateDrugAvailable":false,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[{"id":1.183681712E9,"date":"2013-10-25T14:46:46.360-07:00","type":"Update","version":0.0},{"id":1.183701081E9,"date":"2013-12-17T09:26:12.231-08:00","description":"Removed from FDA Biomarker Table","type":"Update","version":0.0},{"id":1.454200825E9,"date":"2025-08-05T12:06:43.119-07:00","description":"updated label, changed PGx level to Actionable and added Prescribing Info, added Pediatric tag and info","type":"Update","version":0.0}],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":1.5183002E7,"title":"DailyMed - OLANZAPINE AND FLUOXETINE capsule","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003d3c28cf18-01a3-468a-ab3e-8aa82f918251","crossReferences":[{"id":1.45420082E9,"resource":"FDA Drug Label at DailyMed","resourceId":"3c28cf18-01a3-468a-ab3e-8aa82f918251","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003d3c28cf18-01a3-468a-ab3e-8aa82f918251"}],"objCls":"Literature","terms":[{"id":1.45226778E9,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"},{"id":1.5102036E7,"title":"Drugs@FDA: Drug Product Symbyax (Olanzapine and Fluoxetine hydrochloride), NDA021520, Eli Lilly and Company","_sameAs":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event\u003doverview.process\u0026varApplNo\u003d021520","crossReferences":[{"id":1.449754665E9,"resource":"FDA Application","resourceId":"NDA021520","_url":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event\u003doverview.process\u0026varApplNo\u003d021520"}],"objCls":"Literature","terms":[{"id":1.45226778E9,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":true,"pediatric":true,"pediatricMarkdown":{"id":1.454200824E9,"html":"\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eThe safety and efficacy of olanzapine and fluoxetine capsules in patients 10 to 17 years of age has been established for the acute treatment of Depressive Episodes Associated with Bipolar I Disorder in a single 8-week randomized, placebo-controlled clinical trial (N \u003d 255) [see Clinical Studies (14.1)].\u003c/p\u003e\n\u003c/blockquote\u003e\n"},"pgxRelated":true,"prescribingGenes":[{"objCls":"Gene","id":"PA128","symbol":"CYP2D6","name":"cytochrome P450 family 2 subfamily D member 6"}],"prescribingMarkdown":{"id":1.454200823E9,"html":"\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003ePost-marketing cases of QT interval prolongation and ventricular arrhythmia including Torsade de Pointes have been reported in patients treated with fluoxetine. Olanzapine and fluoxetine capsules should be used with caution in patients with congenital long QT syndrome; a previous history of QT prolongation; a family history of long QT syndrome or sudden cardiac death; and other conditions that predispose to QT prolongation and ventricular arrhythmia. Such conditions include [...] conditions that predispose to increased fluoxetine exposure (overdose, hepatic impairment, use of CYP2D6 inhibitors, CYP2D6 poor metabolizer status, or use of other highly protein-bound drugs).\u003c/p\u003e\n\u003c/blockquote\u003e\n"},"relatedAlleles":[],"relatedChemicals":[{"objCls":"Chemical","id":"PA166176027","name":"fluoxetine / olanzapine"}],"relatedGenes":[{"objCls":"Gene","id":"PA128","symbol":"CYP2D6","name":"cytochrome P450 family 2 subfamily D member 6"}],"source":"FDA","summaryMarkdown":{"id":1.450361452E9,"html":"\u003cp\u003eThe FDA-approved drug label for olanzapine and fluoxetine states that fluoxetine is primarily metabolized by CYP2D6, and individuals who are CYP2D6 poor metabolizers metabolized \u003cem\u003eS\u003c/em\u003e-fluoxetine at a slower rate and achieved higher concentrations. Olanzapine and fluoxetine capsules should be used used with caution in patients with congenital long QT syndrome; a previous history of QT prolongation and other conditions that predispose to QT prolongation and ventricular arrhythmia, which include patients with CYP2D6 poor metabolizer status.\u003c/p\u003e\n"},"testing":{"id":1.183672111E9,"resource":"Genetic Testing Level","synonyms":[],"term":"Actionable PGx","termId":"geneTestLevel:1183672111","valid":true},"textMarkdown":{"id":1.450361454E9,"html":"\u003cp\u003eExcerpts from the olanzapine and fluoxetine drug label:\u003c/p\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003e\u003cstrong\u003eQT Prolongation\u003c/strong\u003e\nPost-marketing cases of QT interval prolongation and ventricular arrhythmia including Torsade de Pointes have been reported in patients treated with fluoxetine. Olanzapine and fluoxetine capsules should be used with caution in patients with congenital long QT syndrome; a previous history of QT prolongation; a family history of long QT syndrome or sudden cardiac death; and other conditions that predispose to QT prolongation and ventricular arrhythmia. Such conditions include concomitant use of drugs that prolong the QT interval; hypokalemia or hypomagnesemia; recent myocardial infarction, uncompensated heart failure, bradyarrhythmias, and other significant arrhythmias; and conditions that predispose to increased fluoxetine exposure (overdose, hepatic impairment, use of CYP2D6 inhibitors, CYP2D6 poor metabolizer status, or use of other highly protein-bound drugs). Fluoxetine is primarily metabolized by CYP2D6 [see Contraindications (4.2), Adverse Reactions (6), Drug Interactions (7.7, 7.8), Overdosage\n(10.1), and Clinical Pharmacology (12.3)].\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eFluoxetine is extensively metabolized in the liver to its only identified active metabolite, norfluoxetine, via the CYP2D6 pathway. A number of unidentified metabolites exist.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eDirect glucuronidation and CYP450-mediated oxidation are the primary metabolic pathways for olanzapine. \u003cem\u003eIn vitro\u003c/em\u003e studies suggest that CYP1A2, CYP2D6, and the flavin-containing monooxygenase system are involved in olanzapine oxidation. CYP2D6-mediated oxidation appears to be a minor metabolic pathway \u003cem\u003ein vivo\u003c/em\u003e, because the clearance of olanzapine is not reduced in subjects who are deficient in this enzyme.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eA subset (about 7%) of the population has reduced activity of the drug metabolizing enzyme CYP2D6. Such individuals are referred to as “poor\nmetabolizers” of drugs such as debrisoquin, dextromethorphan, and the tricyclic antidepressants (TCAs). In a study involving labeled and unlabeled enantiomers administered as a racemate, these individuals metabolized \u003cem\u003eS\u003c/em\u003e-fluoxetine at a slower rate and thus achieved higher concentrations of \u003cem\u003eS\u003c/em\u003e-fluoxetine. Consequently, concentrations of \u003cem\u003eS\u003c/em\u003e-norfluoxetine at steady state were lower. The metabolism of \u003cem\u003eR\u003c/em\u003e-fluoxetine in these poor metabolizers appears normal. When compared with normal metabolizers, the total sum at steady state of the plasma concentrations of the 4 enantiomers was not\nsignificantly greater among poor metabolizers. Thus, the net pharmacodynamic activities were essentially the same. Alternative nonsaturable pathways (non-CYP2D6) also contribute to the metabolism of fluoxetine. This explains how fluoxetine achieves a steady-state concentration rather than increasing without limit.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eBecause the metabolism of fluoxetine, like that of a number of other compounds including TCAs and other selective serotonin antidepressants, involves the CYP2D6 system, concomitant therapy with drugs also metabolized by this enzyme system (such as the TCAs) may lead to drug interactions [see Drug Interactions (7.7)].\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eFor the complete drug label text with sections containing pharmacogenetic information highlighted, see the \u003ca download\u003d\"Olanzapine_fluoxetine_2025_08_05_FDA.pdf\" href\u003d\"https://api.clinpgx.org/v1/download/file/attachment/Olanzapine_fluoxetine_2025_08_05_FDA.pdf\"\u003eolanzapine and fluoxetine drug label\u003c/a\u003e.\u003c/p\u003e\n"}}
{"objCls":"Label Annotation","id":"PA166416461","name":"Annotation of FDA Label for ranolazine","alternateDrugAvailable":false,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":1.5183762E7,"title":"DailyMed - RANOLAZINE tablet, film coated, extended release","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003d5b254a8e-db88-49be-bb48-e6d2847f8ab3","crossReferences":[{"id":1.45422882E9,"resource":"FDA Drug Label at DailyMed","resourceId":"5b254a8e-db88-49be-bb48-e6d2847f8ab3","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003d5b254a8e-db88-49be-bb48-e6d2847f8ab3"}],"objCls":"Literature","terms":[{"id":1.452267781E9,"resource":"ClinPGx Tags","term":"Has No PGx","termId":"pgkbTags:1452267781"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":false,"pgxRelated":true,"prescribingGenes":[],"relatedAlleles":[],"relatedChemicals":[{"objCls":"Chemical","id":"PA164746007","name":"ranolazine"}],"relatedGenes":[],"source":"FDA","summaryMarkdown":{"id":1.454228821E9,"html":"\u003cp\u003eThe FDA-approved drug label for ranolazine states that it is metabolized mainly by CYP3A and, to a lesser extent, by CYP2D6.\u003c/p\u003e\n"},"textMarkdown":{"id":1.454228822E9,"html":"\u003cp\u003eExcerpt from the ranolazine label:\u003c/p\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eRanolazine is metabolized mainly by CYP3A and, to a lesser extent, by CYP2D6.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eFor the complete drug label text with sections containing pharmacogenetic information highlighted, see the \u003ca download\u003d\"Ranolazine_2025_08_22_FDA.pdf\" href\u003d\"https://api.clinpgx.org/v1/download/file/attachment/Ranolazine_2025_08_22_FDA.pdf\"\u003eranolazine drug label\u003c/a\u003e.\u003c/p\u003e\n"}}
{"objCls":"Label Annotation","id":"PA166419721","name":"Annotation of FDA Label for isoniazid and NAT2","alternateDrugAvailable":false,"cancerGenome":false,"crossReferences":[],"dosingInformation":false,"history":[],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":1.5185502E7,"title":"DailyMed - ISONIAZID tablet","_sameAs":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003d312cd403-b211-64ef-e063-6394a90aab88","crossReferences":[{"id":1.45427486E9,"resource":"FDA Drug Label at DailyMed","resourceId":"312cd403-b211-64ef-e063-6394a90aab88","_url":"https://dailymed.nlm.nih.gov/dailymed/lookup.cfm?setid\u003d312cd403-b211-64ef-e063-6394a90aab88"}],"objCls":"Literature","terms":[{"id":1.45226778E9,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":true,"pediatricMarkdown":{"id":1.454274863E9,"html":"\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003e\u003cstrong\u003eDOSAGE AND ADMINISTRATION\u003c/strong\u003e [...]\u003c/p\u003e\n\u003cp\u003e\u003cstrong\u003eFor Treatment of Tuberculosis\u003c/strong\u003e [...]\nUsual Oral Dosage (depending on the regimen used): [...]\u003c/p\u003e\n\u003cp\u003eChildren\u003c/p\u003e\n\u003cp\u003e10 mg/kg to 15 mg/kg up to 300 mg daily in a single dose; or\u003c/p\u003e\n\u003cp\u003e20 mg/kg to 40 mg/kg up to 900 mg/day, two or three times/week\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003e\u003cstrong\u003eFor Preventative Therapy of Tuberculosis\u003c/strong\u003e [...]\u003c/p\u003e\n\u003cp\u003eInfants and Children\u003c/p\u003e\n\u003cp\u003e10 mg/kg (up to 300 mg daily) in a single dose. In situations where adherence with daily preventative therapy cannot be assured, 20 mg/kg to 30 mg/kg (not to exceed 900 mg) twice weekly under the direct observation of a health care worker at the time of administration\u003c/p\u003e\n\u003c/blockquote\u003e\n"},"pgxRelated":true,"prescribingGenes":[],"relatedAlleles":[],"relatedChemicals":[{"objCls":"Chemical","id":"PA450112","name":"isoniazid"}],"relatedGenes":[{"objCls":"Gene","id":"PA18","symbol":"NAT2","name":"N-acetyltransferase 2"}],"source":"FDA","summaryMarkdown":{"id":1.454274861E9,"html":"\u003cp\u003eThe FDA-approved drug label for isoniazid states that \u0026quot;slow inactivators\u0026quot; of isoniazid may be more susceptible to drug toxicity due to higher blood levels of the drug. Acetylator status of an individual can be determined by examining genetic variants in the NAT2 gene. However, the label never mentions any specific gene with regard to inactivator or acetylator status.\u003c/p\u003e\n"},"testing":{"id":1.183672141E9,"resource":"Genetic Testing Level","synonyms":[],"term":"Informative PGx","termId":"geneTestLevel:1183672141","valid":true},"textMarkdown":{"id":1.454274862E9,"html":"\u003cp\u003eExcerpts from the isoniazid label:\u003c/p\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eIsoniazid is metabolized primarily by acetylation and dehydrazination. The rate of acetylation is genetically determined. Approximately 50 percent of Blacks and Caucasians are \u0026quot;slow inactivators\u0026quot; and the rest are \u0026quot;rapid inactivators\u0026quot;; the majority of Eskimos and Orientals are \u0026quot;rapid inactivators.\u0026quot;\u003c/p\u003e\n\u003cp\u003eThe rate of acetylation does not significantly alter the effectiveness of isoniazid. However, slow acetylation may lead to higher blood levels of the drug and, thus, to an\nincrease in toxic reactions.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eFor the complete drug label text with sections containing pharmacogenetic information highlighted, see the \u003ca download\u003d\"Isoniazid_2025_09_25_FDA.pdf\" href\u003d\"https://api.clinpgx.org/v1/download/file/attachment/Isoniazid_2025_09_25_FDA.pdf\"\u003eisoniazid drug label\u003c/a\u003e.\u003c/p\u003e\n"}}
{"objCls":"Label Annotation","id":"PA166104802","name":"Annotation of FDA Label for capecitabine and DPYD","alternateDrugAvailable":true,"biomarkerStatus":"On FDA Biomarker List","cancerGenome":false,"crossReferences":[],"dosingInformation":true,"history":[{"id":1.183681518E9,"date":"2013-10-25T12:25:22.795-07:00","type":"Update","version":0.0},{"id":1.450399696E9,"date":"2019-05-10T08:42:29.125-07:00","description":"Added prescribing info","type":"Update","version":0.0},{"id":1.4519685E9,"date":"2022-12-19T15:33:11.126-08:00","description":"update label, PGx level","type":"Update","version":0.0},{"id":1.454288442E9,"date":"2025-10-08T10:10:41.762-07:00","description":"updated label and annotation, changed PGx level to Testing Required","type":"Update","version":0.0}],"indication":false,"labelApplications":[],"labelDocumentAvailable":true,"literature":[{"id":1.5186282E7,"title":"Drugs@FDA: Drug Product Xeloda (capecitabine), H2-Pharma, LLC - NDA020896/SUPPL-52, 10/03/2025","_sameAs":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event\u003doverview.process\u0026varApplNo\u003d020896","crossReferences":[{"id":1.454288441E9,"resource":"FDA Application","resourceId":"NDA020896/SUPPL-52","_url":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event\u003doverview.process\u0026varApplNo\u003d020896"}],"objCls":"Literature","pubDate":"2025-10-03T00:00:00-07:00","terms":[{"id":1.45226778E9,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"},{"id":1.5101916E7,"title":"Drugs@FDA: Drug Product Xeloda (capecitabine), NDA020896, Genentech, Inc.","_sameAs":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event\u003doverview.process\u0026varApplNo\u003d020896","crossReferences":[{"id":1.449894845E9,"resource":"FDA Application","resourceId":"NDA020896","_url":"https://www.accessdata.fda.gov/scripts/cder/daf/index.cfm?event\u003doverview.process\u0026varApplNo\u003d020896"}],"objCls":"Literature","terms":[{"id":1.45226778E9,"resource":"ClinPGx Tags","term":"Has PGx","termId":"pgkbTags:1452267780"}],"type":"Drug Label"}],"otherPrescribingGuidance":false,"pediatric":false,"pgxRelated":true,"prescribingGenes":[{"objCls":"Gene","id":"PA145","symbol":"DPYD","name":"dihydropyrimidine dehydrogenase"}],"prescribingMarkdown":{"id":1.450399695E9,"html":"\u003cp\u003eExcerpts from the capecitabine (XELODA) drug label:\u003c/p\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003ePrior to initiating XELODA, test patients for genetic variants of the \u003cem\u003eDPYD\u003c/em\u003e gene unless immediate treatment is necessary [...]. Serious adverse reactions may still occur even if no DPYD variants are identified.\u003c/p\u003e\n\u003cp\u003eAvoid use of XELODA in patients with certain homozygous or compound heterozygous \u003cem\u003eDPYD\u003c/em\u003e variants that result in complete DPD deficiency.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003ePatients with certain homozygous or compound heterozygous variants in the \u003cem\u003eDPYD\u003c/em\u003e gene known to result in complete or near complete absence of DPD activity (complete DPD deficiency) are at increased risk for acute early-onset toxicity and serious, including fatal, adverse reactions due to XELODA (e.g., mucositis, diarrhea, neutropenia, and neurotoxicity). Patients with partial DPD activity (partial DPD deficiency) may also have increased risk of serious, or fatal, adverse reactions.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eWithhold or permanently discontinue XELODA based on clinical assessment of the onset, duration, and severity of adverse reactions in patients with evidence of acute early-onset or unusually severe reactions. No XELODA dose has been proven safe for patients with complete DPD deficiency. For patients with partial DPD deficiency, individualize the dosage and modify based on tolerability and intent of treatment.\u003c/p\u003e\n\u003c/blockquote\u003e\n"},"relatedAlleles":[{"objCls":"Haplotype","id":"PA166171120","symbol":"DPYD c.1129-5923C\u003eG, c.1236G\u003eA (HapB3)","name":"c.1129-5923C\u003eG, c.1236G\u003eA (HapB3)"},{"objCls":"Variant","id":"PA166153919","symbol":"rs115232898","name":"rs115232898"},{"objCls":"Variant","id":"PA166153760","symbol":"rs3918290","name":"rs3918290"},{"objCls":"Variant","id":"PA166153888","symbol":"rs55886062","name":"rs55886062"},{"objCls":"Variant","id":"PA166153895","symbol":"rs67376798","name":"rs67376798"},{"objCls":"Variant","id":"PA166153906","symbol":"rs75017182","name":"rs75017182"}],"relatedChemicals":[{"objCls":"Chemical","id":"PA448771","name":"capecitabine"}],"relatedGenes":[{"objCls":"Gene","id":"PA145","symbol":"DPYD","name":"dihydropyrimidine dehydrogenase"}],"source":"FDA","summaryMarkdown":{"id":1.450342104E9,"html":"\u003cp\u003eThe FDA-approved label for capecitabine (XELODA) states that patients should be tested for genetic variants of the \u003cem\u003eDPYD\u003c/em\u003e gene prior to initiating treatment unless immediate treatment is necessary. Patients with certain homozygous or compound heterozygous variants in the \u003cem\u003eDPYD\u003c/em\u003e gene are at increased risk for acute early-onset toxicity and serious, including fatal, adverse reactions due to capecitabine.  Patients with partial DPD deficiency may also have increased risk of serious, or fatal, adverse reactions; their dosage should be individualized and modified based on tolerability and intent of treatment.\u003c/p\u003e\n"},"testing":{"id":1.183672041E9,"resource":"Genetic Testing Level","synonyms":[],"term":"Testing Required","termId":"geneTestLevel:1183672041","valid":true},"textMarkdown":{"id":1.450342105E9,"html":"\u003cp\u003eCapecitabine is a pro-drug of 5-fluorouracil used for the treatment of various types of neoplasms including colorectal and breast neoplasms. Variants in the \u003cem\u003eDPYD\u003c/em\u003e gene (also known as dihydropyrimidine dehydrogenase and DPD) are associated with increased risk for adverse events. See the \u003ca href\u003d\"/pathway/PA150653776\"\u003eFluroropyrimidine Pathway\u003c/a\u003e and \u003ca href\u003d\"/vip/PA145\"\u003eDPYD VIP\u003c/a\u003e for more information.\u003c/p\u003e\n\u003cp\u003eExcerpts from the capecitabine (XELODA) drug label:\u003c/p\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003ePrior to initiating XELODA, test patients for genetic variants of the \u003cem\u003eDPYD\u003c/em\u003e gene unless immediate treatment is necessary. An FDA-authorized test for the detection of the \u003cem\u003eDPYD\u003c/em\u003e gene to identify patients at risk of serious adverse reactions with XELODA is not currently available. Currently available tests used to identify \u003cem\u003eDPYD\u003c/em\u003e variants may vary in accuracy and design (e.g., which \u003cem\u003eDPYD\u003c/em\u003e variant(s) they identify).\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003eAvoid use of XELODA in patients known to have certain homozygous or compound heterozygous \u003cem\u003eDPYD\u003c/em\u003e variants that result in complete DPD deficiency. No XELODA dose has been proven safe for patients with complete DPD deficiency. For patients with partial DPD deficiency, individualize the dosage and modify based on tolerability and intent of treatment [see Warnings and Precautions (5.1)].\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003ePatients with certain homozygous or compound heterozygous variants in the \u003cem\u003eDPYD\u003c/em\u003e gene known to result in complete or near complete absence of DPD activity (complete DPD deficiency) are at increased risk for acute early-onset toxicity and serious, including fatal, adverse reactions due to XELODA (e.g., mucositis, diarrhea, neutropenia, and neurotoxicity). Patients with partial DPD activity (partial DPD deficiency) may also have increased risk of serious, or fatal, adverse reactions.\u003c/p\u003e\n\u003cp\u003ePrior to initiating XELODA, test patients for genetic variants of the \u003cem\u003eDPYD\u003c/em\u003e gene unless immediate treatment is necessary [see Clinical Pharmacology (12.5)]. Serious adverse reactions may still occur even if no \u003cem\u003eDPYD\u003c/em\u003e variants are identified.\u003c/p\u003e\n\u003cp\u003eAvoid use of XELODA in patients with certain homozygous or compound heterozygous \u003cem\u003eDPYD\u003c/em\u003e variants that result in complete DPD deficiency.\u003c/p\u003e\n\u003cp\u003eWithhold or permanently discontinue XELODA based on clinical assessment of the onset, duration, and severity of adverse reactions in patients with evidence of acute early-onset or unusually severe reactions. No XELODA dose has been proven safe for patients with complete DPD deficiency. For patients with partial DPD deficiency, individualize the dosage and modify based on tolerability and intent of treatment.\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cblockquote class\u003d\"blockquote\"\u003e\n\u003cp\u003ePharmacogenomics: The \u003cem\u003eDPYD\u003c/em\u003e gene encodes the enzyme DPD, which is responsible for the catabolism of \u0026gt;80% of fluorouracil. Approximately 3-5% of White populations have partial DPD deficiency and 0.2% of White populations have complete DPD deficiency, which may be due to certain genetic no function or decreased function variants in \u003cem\u003eDPYD\u003c/em\u003e resulting in partial to complete or near complete absence of enzyme activity. DPD deficiency is estimated to be more prevalent in Black or African American populations compared to White populations. Insufficient information is available to estimate the prevalence of DPD deficiency in other populations.\u003c/p\u003e\n\u003cp\u003ePatients who are homozygous or compound heterozygous for no function \u003cem\u003eDPYD\u003c/em\u003e variants (i.e., carry two \u003cem\u003eDPYD\u003c/em\u003e variants that results in no DPD enzyme activity) or are compound heterozygous for a no function \u003cem\u003eDPYD\u003c/em\u003e variant plus a decreased function \u003cem\u003eDPYD\u003c/em\u003e variant have complete DPD deficiency and are at increased risk for acute early-onset of toxicity and serious life-threatening, or fatal adverse reactions with XELODA. Partial DPD deficiency can result from the presence of either two decreased function \u003cem\u003eDPYD\u003c/em\u003e variants or one normal function plus either a decreased function or a no function \u003cem\u003eDPYD\u003c/em\u003e variant. Patients with partial DPD deficiency may also be at an increased risk for toxicity from XELODA.\u003c/p\u003e\n\u003cp\u003eSeveral \u003cem\u003eDPYD\u003c/em\u003e variants observed with variable frequency across populations have been associated with reduced or no DPD activity, especially when present as homozygous or compound heterozygous variants. These include c.1905+1G\u0026gt;A (\u003cem\u003eDPYD\u003c/em\u003e *2A), c.1679T\u0026gt;G (\u003cem\u003eDPYD\u003c/em\u003e *13), c.2846A\u0026gt;T, c.1129-5923C\u0026gt;G (Haplotype B3), and c557A\u0026gt;G. \u003cem\u003eDPYD\u003c/em\u003e*2A and \u003cem\u003eDPYD\u003c/em\u003e*13 are no function variants, and c.2846A\u0026gt;T, c.1129-5923C\u0026gt;G, and c557A\u0026gt;G are decreased function variants. This is not a complete listing of all \u003cem\u003eDPYD\u003c/em\u003e variants that may result in DPD deficiency [see Warnings and Precautions (5.1)].\u003c/p\u003e\n\u003c/blockquote\u003e\n\u003cp\u003eFor the complete drug label text with sections containing pharmacogenetic information highlighted, see the \u003ca download\u003d\"Capecitabine_2025_10_08_FDA.pdf\" href\u003d\"https://api.clinpgx.org/v1/download/file/attachment/Capecitabine_2025_10_08_FDA.pdf\"\u003ecapecitabine drug label\u003c/a\u003e.\u003c/p\u003e\n"}}
